<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_visibility_demo.xml — visibility 属性演示 Fragment 布局

    布局结构：
      ScrollView
        └── LinearLayout（竖向）
            ├── 说明标题
            ├── MaterialCardView（带边框，三色 View 容器）
            │    └── LinearLayout（横向三个固定宽度的 View）
            ├── 颜色标注行
            ├── 切换按钮行
            ├── 代码说明标题
            └── 代码卡片（带边框）
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── 效果预览区标题 ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="效果预览"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp" />

        <!-- 三色 View 容器（带描边卡片作边框） -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant">

            <!-- 横向三个固定宽度的 TextView，直接在组件内显示标签 -->
            <LinearLayout
                android:id="@+id/containerViews"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:orientation="horizontal"
                android:padding="8dp">

                <!-- View A：绿色，始终可见 -->
                <TextView
                    android:id="@+id/viewA"
                    android:layout_width="80dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="4dp"
                    android:background="#2E7D32"
                    android:gravity="center"
                    android:text="A"
                    android:textColor="#FFFFFF"
                    android:textAppearance="?attr/textAppearanceTitleMedium" />

                <!-- View B：蓝色，被控制的演示对象；GONE 时 C 自动填补位置 -->
                <TextView
                    android:id="@+id/viewB"
                    android:layout_width="80dp"
                    android:layout_height="match_parent"
                    android:layout_marginHorizontal="4dp"
                    android:background="#1565C0"
                    android:gravity="center"
                    android:text="B"
                    android:textColor="#FFFFFF"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:visibility="visible" />

                <!-- View C：橙色，始终可见，用于体现位置变化 -->
                <TextView
                    android:id="@+id/viewC"
                    android:layout_width="80dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="4dp"
                    android:background="#E65100"
                    android:gravity="center"
                    android:text="C"
                    android:textColor="#FFFFFF"
                    android:textAppearance="?attr/textAppearanceTitleMedium" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ── 控制按钮 ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="切换 View B 的 visibility"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVisible"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="VISIBLE" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnInvisible"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:text="INVISIBLE" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGone"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="GONE" />

        </LinearLayout>

        <!-- ── 布局代码展示 ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="对应布局代码（核心属性）"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/codeLine1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="&lt;View"
                    android:fontFamily="monospace"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <TextView
                    android:id="@+id/codeLine2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="    android:id=&quot;@+id/viewB&quot;"
                    android:fontFamily="monospace"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <TextView
                    android:id="@+id/codeLine3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="    android:layout_width=&quot;80dp&quot;"
                    android:fontFamily="monospace"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <!-- 高亮行：visibility 取值 -->
                <TextView
                    android:id="@+id/codeLineVisibility"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    tools:text='    android:visibility="visible"' />

                <TextView
                    android:id="@+id/codeLine5"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="    android:background=&quot;#1565C0&quot; /&gt;"
                    android:fontFamily="monospace"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
